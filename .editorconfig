root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# The Java sources are mixed tabs/spaces with a slight majority of spaces.
# Standardise on 4-space indent for new and reformatted files - existing
# files keep working because Checkstyle isn't enforcing indent_style.
[*.java]
indent_style = space
indent_size = 4

[*.{xml,json,yml,yaml,properties}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
